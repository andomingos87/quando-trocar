# WhatsApp number (only digits, with country + area code)
NEXT_PUBLIC_WHATSAPP_NUMBER=15556669965


# Contact email shown in the footer
NEXT_PUBLIC_CONTACT_EMAIL=contato@quandotrocar.com.br

# Public site URL (used for OG metadata)
NEXT_PUBLIC_SITE_URL=https://quandotrocar.com.br

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# OPENAI
OPENAI_API_KEY=replace_with_openai_api_key

WHATSAPP_VERIFY_TOKEN=replace_with_custom_verify_token
WHATSAPP_APP_SECRET=replace_with_meta_app_secret
WHATSAPP_ACCESS_TOKEN=replace_with_meta_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=711033778757532
INTERNAL_JOB_SECRET=replace_with_internal_job_secret

# Meta WhatsApp templates (aprovados na Meta antes de usar)
# Template OTP — categoria "Authentication" — usado no login do painel da oficina e do admin
WHATSAPP_TEMPLATE_OTP_NAME=replace_with_approved_otp_template_name
# Template cobrança — categoria "Utility" — usado pelo cron de billing do painel admin
WHATSAPP_TEMPLATE_COBRANCA_NAME=replace_with_approved_cobranca_template_name

# Painel admin (Admin-1 a Admin-6)
ADMIN_SESSION_SECRET=replace_with_random_secret_min_32_chars
# Default: 7. Quantos dias de tolerância antes de auto-pausar oficina inadimplente
INADIMPLENCIA_DIAS_GRACE=7
# Só ambiente dev — fixa código OTP para bypass; deixe vazio em produção
ADMIN_OTP_DEV_BYPASS_CODE=

# Mercado Pago (Admin-6) — Anderson preenche quando chegar nessa sub-fase
MERCADO_PAGO_ACCESS_TOKEN=replace_with_mercado_pago_access_token
MERCADO_PAGO_WEBHOOK_SECRET=replace_with_mercado_pago_webhook_secret
